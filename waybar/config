{
    "layer": "top",
    "position": "top",
    "height": 0,
    "margin-top": 8,
    "margin-left": 16,
    "margin-right": 16,
    "spacing": 0,

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "group/media",
        "group/system",
        "battery",
        "custom/power"
    ],

    "group/media": {
        "orientation": "horizontal",
        "modules": ["pulseaudio", "network"]
    },

    "group/system": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory", "temperature"]
    },

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "all-outputs": true
    },

    "hyprland/window": {
        "format": "{title}",
        "max-length": 35,
        "separate-outputs": true,
        "rewrite": {
            "(.*) βÄî Mozilla Firefox":        " Firefox",
            "(.*) - Visual Studio Code":     "σΑ®û VS Code",
            "kitty":                          " kitty",
            "(.*)Steam(.*)":                 "σΑ™™ Steam",
            "(.*)Discord(.*)":              "σΑô· Discord",
            "(.*)Dolphin(.*)":               " Files"
        }
    },

    "clock": {
        "format": " {:%H:%M   %a %d %b}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "σΑ•¹",
        "format-icons": {
            "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5,
        "tooltip": false
    },

    "network": {
        "format-wifi": "σΑ•© {essid}",
        "format-ethernet": "σΑàÄ {ifname}",
        "format-disconnected": "σΑΛ≠",
        "on-click": "kitty --class float_network -e nmtui",
        "tooltip-format": "σΑΛ¥ {bandwidthDownBits}  σΑΛß {bandwidthUpBits}\n{ifname}: {ipaddr}"
    },

    "cpu": {
        "format": "σΑΜ† {usage}%",
        "interval": 2,
        "on-click": "kitty --class float_system_monitor -e btop",
        "tooltip": false
    },

    "memory": {
        "format": "σΑç¦ {used:0.1f}G",
        "on-click": "kitty --class float_system_monitor -e btop",
        "tooltip": false
    },

    "temperature": {
        "format": " {temperatureC}¬Α",
        "critical-threshold": 80,
        "format-critical": "σΑΗ¹ {temperatureC}¬Α",
        "tooltip": false
    },

    "battery": {
        "interval": 30,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "σΑ²³ {capacity}%",
        "format-plugged": "σΑöΞ {capacity}%",
        "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
        "on-click": "kitty --class float_system_monitor -e btop"
    },

    "custom/power": {
        "format": "σΑêΞ",
        "on-click": "~/.config/hypr/waybar/scripts/quick-settings.sh",
        "tooltip": false
    },

    "tray": {
        "icon-size": 15,
        "spacing": 6
    }
}